rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }
    match /debtRequests/{id} {
      allow read, write: if true;
    }
    match /debts/{debtId} {
      allow read, write: if true;
      match /transactions/{txId} {
        allow read, write: if true;
      }
    }
    match /notifications/{id} {
      allow read, write: if true;
    }
    match /ratings/{id} {
      allow read, write: if true;
    }
    match /activityLog/{id} {
      allow read, write: if true;
    }
  }
}
